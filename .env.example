# Production Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-browser-safe-anon-or-publishable-key
SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key
# Legacy fallback if you have not moved to secret keys yet:
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key

# Session Security
SESSION_SECRET=your-secure-random-session-secret-here-minimum-32-characters

# Admin Credentials (REQUIRED for production)
ADMIN_EMAIL=your-admin-email@domain.com
ADMIN_PASSWORD=your-secure-admin-password

# External API Keys (Optional - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
OPENROUTER_API_KEY=sk-ant-your-openrouter-key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key

# Production Settings
NODE_ENV=production
PORT=5000

# IMPORTANT SECURITY NOTES:
# 1. Use strong, unique passwords
# 2. Keep API keys secure and rotate them regularly  
# 3. Never commit this file to version control
# 4. Use environment variable management in production
# 5. Never expose SUPABASE_SECRET_KEY or SUPABASE_SERVICE_ROLE_KEY to the browser
# 6. Keep RLS enabled on all public-schema tables in Supabase